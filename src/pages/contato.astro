---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_LINKS } from '../lib/site';
---

<Base title="Contato" description="Fale com a Companhia do Aventureiro.">
  <section class="mx-auto max-w-3xl px-4 py-14">
    <h1 class="text-4xl font-black text-text-primary">Contato</h1>
    <p class="mt-3 text-text-secondary">
      Dúvidas, sugestões, parcerias ou só quer bater um papo? Manda pra gente.
    </p>

    <div class="mt-8 flex flex-wrap gap-4 text-sm text-text-secondary">
      <a href={`mailto:${SITE_LINKS.email}`} class="hover:text-accent-yellow">{SITE_LINKS.email}</a>
      <a href={SITE_LINKS.instagram} target="_blank" rel="noopener noreferrer" class="hover:text-accent-yellow">
        Instagram
      </a>
    </div>

    <div class="mt-10">
      <ContactForm subjectPrefix="Contato pelo site" messageLabel="Sua mensagem" submitLabel="Enviar mensagem" />
    </div>
  </section>
</Base>
