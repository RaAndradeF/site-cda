---
import Base from '../layouts/Base.astro';
import PodcastLinks from '../components/PodcastLinks.astro';
import { fetchPodcastFeed } from '../lib/fetchRss';

const feed = await fetchPodcastFeed();
---

<Base title="Sobre" description={feed.channel.description}>
  <section class="mx-auto max-w-3xl px-4 py-14">
    <h1 class="text-4xl font-black text-text-primary">Sobre o podcast</h1>

    <p class="mt-6 text-text-secondary leading-relaxed whitespace-pre-line">
      {feed.channel.description}
    </p>

    <div class="mt-10">
      <h2 class="text-xl font-bold text-accent-yellow mb-4">Ouça em todas as plataformas</h2>
      <PodcastLinks />
    </div>
  </section>
</Base>
