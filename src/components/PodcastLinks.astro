---
//Lucide-React
import { Music, Rss, Headphones, ShoppingBag } from 'lucide-react';
//React-Icons
import { FaSpotify, FaDeezer, FaRssSquare} from 'react-icons/fa';
import { SiApplepodcasts,SiPocketcasts } from 'react-icons/si';

import { SITE_LINKS } from '../lib/site';

//Retirado link de loja temporariamente
const platforms = [
  { href: SITE_LINKS.spotify, label: 'Spotify', Icon: FaSpotify},
  { href: SITE_LINKS.applePodcasts, label: 'Apple Podcasts', Icon: SiApplepodcasts },
  { href: SITE_LINKS.deezer, label: 'Deezer', Icon: FaDeezer },
  { href: SITE_LINKS.pocketCasts, label: 'Pocketcasts', Icon: SiPocketcasts },
  //{ href: SITE_LINKS.googlePodcasts, label: 'Google Podcasts', Icon: Headphones },
  { href: SITE_LINKS.rss, label: 'RSS', Icon: FaRssSquare },
  //{ href: SITE_LINKS.loja, label: 'Loja', Icon: ShoppingBag }
];
---

<div class="flex flex-wrap gap-3">
  {platforms.map(({ href, label, Icon }) => (
    <a
      href={href}
      target={href.startsWith('http') ? '_blank' : undefined}
      rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
      class="inline-flex items-center gap-2 rounded-full bg-bg-card/80 hover:bg-bg-hover px-4 py-2 text-sm font-semibold text-text-primary transition-colors border border-primary-light/30"
    >
      <Icon size={18} />
      {label}
    </a>
  ))}
</div>
