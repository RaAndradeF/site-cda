---
import { withBase } from '../lib/site';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  duration: string;
  image?: string;
  featured?: boolean;
}

const { slug, title, description, pubDate, duration, image, featured = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric'
}).format(pubDate);
---

<a
  href={withBase(`/podcast/${slug}`)}
  class={`group flex flex-col rounded-2xl bg-bg-card/80 border overflow-hidden transition-colors ${
    featured ? 'border-accent-yellow' : 'border-primary-light/30 hover:border-accent-yellow'
  }`}
>
  {image && (
    <img src={image} alt={title} loading="lazy" class="h-44 w-full object-cover" />
  )}
  <div class="flex flex-1 flex-col p-4">
    {featured && (
      <span class="mb-2 inline-block w-fit rounded-full bg-accent-yellow px-3 py-1 text-xs font-bold text-primary-dark">
        Em destaque
      </span>
    )}
    <h3 class="font-bold text-text-primary group-hover:text-accent-yellow transition-colors line-clamp-2">
      {title}
    </h3>
    <p class="mt-2 text-sm text-text-secondary line-clamp-3 flex-1">{description}</p>
    <div class="mt-4 flex items-center gap-4 text-xs text-text-muted">
      <span>{formattedDate}</span>
      <span>{duration}</span>
    </div>
  </div>
</a>
