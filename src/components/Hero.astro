---
import PodcastLinks from './PodcastLinks.astro';
import { SITE_TAGLINE } from '../lib/site';

import { Image } from 'astro:assets';
import brand from '../assets/images/brand.png';
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-dark via-primary to-secondary-dark">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_20%_20%,var(--color-accent-yellow),transparent_35%),radial-gradient(circle_at_80%_0%,var(--color-accent-red),transparent_35%)]">
  </div>

  <div class="relative mx-auto max-w-6xl px-4 py-20 sm:py-28 text-center">
    <span class="inline-block mx-auto mb-6 h-64 w-64 rounded-full bg-transparent text-white grid place-items-center font-black text-2xl shadow-lg">
      <Image src={brand} alt="Logo da Companhia do Aventureiro"/>
    </span>

    <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-text-primary">
      Companhia do <span class="text-accent-yellow">Aventureiro</span>
    </h1>

    <p class="mt-4 max-w-2xl mx-auto text-lg text-secondary-light">
      {SITE_TAGLINE}
    </p>

    <div class="mt-8 flex justify-center">
      <PodcastLinks />
    </div>
  </div>
</section>
